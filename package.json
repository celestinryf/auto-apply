{
  "name": "auto-apply",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env BROWSER=chrome vite",
    "dev:firefox": "cross-env BROWSER=firefox vite",
    "build": "cross-env BROWSER=chrome vite build",
    "build:firefox": "cross-env BROWSER=firefox vite build",
    "build:all": "npm run build && npm run build:firefox",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:dom": "vitest run tests/dom",
    "test:coverage": "vitest run tests/unit tests/integration --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:all": "npm run test:coverage && npm run test:dom && npm run test:e2e"
  },
  "description": "Auto-fill job applications with your profile data",
  "dependencies": {
    "@preact/signals": "^2.8.1",
    "dexie": "^4.3.0",
    "pdfjs-dist": "^5.4.624",
    "preact": "^10.28.4",
    "webextension-polyfill": "^0.12.0",
    "@anthropic-ai/sdk": "^0.78.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@playwright/test": "^1.55.0",
    "cross-env": "^10.1.0",
    "jsdom": "^26.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-web-extension": "^4.5.0",
    "vitest": "^2.1.9"
  }
}
